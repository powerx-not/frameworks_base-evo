<resources>

    <!-- App error dialog -->
    <java-symbol type="id" name="aerr_copy" />
    <java-symbol type="string" name="url_copy_success" />
    <java-symbol type="string" name="url_copy_failed" />

    <!-- Light / Regular style fonts -->
    <java-symbol type="string" name="config_lightFontFamily" />
    <java-symbol type="string" name="config_regularFontFamily" />

    <!-- Default line spacing multiplier between hours and minutes of the keyguard clock-->
    <java-symbol type="dimen" format="float" name="keyguard_clock_line_spacing_scale" />

    <!-- Whether to cancel fingerprint operation if not idle -->
    <java-symbol type="bool" name="config_fpCancelIfNotIdle" />

    <!-- Whether to force enable multi resolution configuration for camera -->
    <java-symbol type="bool" name="config_forceMultiResolution" />

    <java-symbol type="array" name="config_launcherComponents" />
    <java-symbol type="array" name="config_launcherPackages" />

    <!-- Whitelist of package names to bypass foreground service type validation -->
    <java-symbol type="array" name="config_fgsTypeValidationBypassPackages"/>

    <!-- Whitelist of package names to bypass alarm manager validation -->
    <java-symbol type="array" name="config_alarmManagerValidationBypassPackages"/>

    <!-- Whitelist of package names to bypass broadcast reciever validation -->
    <java-symbol type="array" name="config_broadcaseReceiverValidationBypassPackages"/>

    <!-- Define device configs on boot -->
    <java-symbol type="array" name="global_device_configs_override" />
    <java-symbol type="array" name="device_configs_override" />

    <!-- Settings Restart -->
    <java-symbol type="string" name="settings_restart_title" />
    <java-symbol type="string" name="settings_restart_message" />

    <!-- Soft restart dialog -->
    <java-symbol type="string" name="system_restart_title" />
    <java-symbol type="string" name="system_restart_message" />

    <!-- SystemUI restart dialog -->
    <java-symbol type="string" name="systemui_restart_title" />
    <java-symbol type="string" name="systemui_restart_message" />

    <!-- Launcher restart dialog -->
    <java-symbol type="string" name="launcher_restart_title" />
    <java-symbol type="string" name="launcher_restart_message" />

    <!-- Whether device has dash charging support -->
    <java-symbol type="bool" name="config_hasDashCharger" />

    <!-- Whether device has warp charging support -->
    <java-symbol type="bool" name="config_hasWarpCharger" />

    <!-- Whether device has VOOC charging support -->
    <java-symbol type="bool" name="config_hasVoocCharger" />

    <!-- Whether device has turbo power charging support -->
    <java-symbol type="bool" name="config_hasTurboPowerCharger" />

    <!-- Path to fast charging status file to detect whether an oem fast charger is active -->
    <java-symbol type="string" name="config_oemFastChargerStatusPath" />

    <!-- Path to fast charging status file to detect whether an oem fast charger is active -->
    <java-symbol type="string" name="config_oemFastChargerStatusPath2" />

    <!-- Expected value from fast charging status file -->
    <java-symbol type="string" name="config_oemFastChargerStatusValue" />

    <!-- Display color inversion availability -->
    <java-symbol type="bool" name="config_displayInversionAvailable" />

    <!-- Smart 5G -->
    <java-symbol type="bool" name="config_supportSmart5G" />

    <!-- Whether device has a physical display cutout -->
    <java-symbol type="bool" name="config_physicalDisplayCutout" />

    <!-- Whether device has a big physical display cutout -->
    <java-symbol type="bool" name="config_physicalDisplayCutoutCentered" />

    <!-- Cycle through ringer modes -->
    <java-symbol type="string" name="volume_dialog_ringer_guidance_normal" />

    <!-- PowerOffAlarmService -->
    <java-symbol type="bool" name="config_powerOffAlarmEnabled" />
    <java-symbol type="string" name="notification_channel_poweroff_alarm" />
    <java-symbol type="string" name="poweroff_alarm_title" />
    <java-symbol type="string" name="poweroff_alarm_body" />
    <java-symbol type="drawable" name="ic_alarm_on" />

