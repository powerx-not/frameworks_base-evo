<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_gravity="center|top"
    android:gravity="center|top"
    android:orientation="vertical">

    <FrameLayout
        android:layout_width="310dp"
        android:layout_height="200dp"
        android:layout_gravity="center"
        android:background="@drawable/lockscreen_clock_29_bg"
        tools:ignore="UselessParent">

        <ImageView
            android:id="@+id/user_profile_icon"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_gravity="end"
            android:layout_marginTop="12dp"
            android:layout_marginEnd="40dp"
            android:scaleType="centerCrop"
            android:importantForAccessibility="no"
            android:src="@drawable/lockscreen_clock_27_logo"
            android:tag="profile_picture" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="start|center"
            android:layout_marginStart="28dp"
            android:layout_marginTop="32dp"
            android:layout_marginBottom="22dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/user_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="2dp"
                android:includeFontPadding="false"
                android:tag="accent1|nolineheight|username"
                android:text="Onii-Chan!!"
                android:fontFamily="@*android:string/config_clockFontFamily"
                android:textColor="@android:color/system_accent1_300"
                android:textSize="22sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:includeFontPadding="false"
                android:layout_marginBottom="2dp"
                android:tag="text1"
                android:text="Now It's"
                android:textColor="#FFFFFF"
                android:textSize="16sp" />

            <TextClock
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:format12Hour="hh • mm a"
                android:format24Hour="kk • mm a"
                android:includeFontPadding="false"
                android:layout_marginBottom="2dp"
                android:tag="accent1"
                android:fontFamily="@*android:string/config_clockFontFamily"
                android:textColor="@android:color/system_accent1_200"
                android:textSize="14sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:includeFontPadding="false"
                android:layout_marginBottom="2dp"
                android:tag="text1"
                android:text="Today is"
                android:textColor="#FFFFFF"
                android:textSize="16sp" />

            <TextClock
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:format12Hour="EEEE dd MMMM"
                android:format24Hour="EEEE dd MMMM"
                android:includeFontPadding="false"
                android:layout_marginBottom="2dp"
                android:tag="accent1"
                android:fontFamily="@*android:string/config_clockFontFamily"
                android:textColor="@android:color/system_accent1_200"
                android:textSize="14sp" />
                
            <LinearLayout
		        android:layout_width="match_parent"
		        android:layout_height="wrap_content"
		        android:orientation="horizontal"
		        android:gravity="start|center">

                <com.android.systemui.weather.WeatherImageView
                    android:id="@+id/weather_image"
                    android:layout_width="14sp"
                    android:layout_height="14sp"
                    android:layout_gravity="center_vertical"
                    android:layout_marginEnd="4dp"
                    android:scaleType="fitCenter"
                    android:visibility="gone" />

                <com.android.systemui.weather.WeatherTextView
                    android:id="@+id/weather_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:layout_gravity="center_vertical"
                    android:fontFamily="@*android:string/config_clockFontFamily"
                    android:textColor="@android:color/system_accent1_200"
                    android:visibility="gone"
                    android:textSize="14sp" />
            </LinearLayout>
        </LinearLayout>
    </FrameLayout>
</LinearLayout>
