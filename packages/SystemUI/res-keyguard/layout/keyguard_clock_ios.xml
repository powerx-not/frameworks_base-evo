<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/clock_frame"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_gravity="center_horizontal|top"
    android:gravity="center_horizontal|top"
    android:orientation="vertical">

    <TextClock
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:format12Hour="EEEE, MMMM dd"
        android:format24Hour="EEEE, dd MMMM"
        android:gravity="center"
        android:singleLine="true"
        android:tag="text1|nolineheight"
        android:textAlignment="center"
        android:textColor="@android:color/white"
        android:textSize="23sp"
        android:textStyle="bold" />

    <TextClock
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:alpha="0.9"
        android:fontFamily="@*android:string/config_clockFontFamily"
        android:format12Hour="hh:mm"
        android:format24Hour="HH:mm"
        android:gravity="center"
        android:singleLine="true"
        android:tag="text1"
        android:textAlignment="center"
        android:textColor="@android:color/white"
        android:textSize="110sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:gravity="center_horizontal"
        android:orientation="horizontal">

        <com.android.systemui.weather.WeatherImageView
            android:id="@+id/weather_image"
            android:layout_width="18sp"
            android:layout_height="18sp"
            android:layout_gravity="center_vertical"
            android:layout_marginEnd="4dp"
            android:scaleType="fitCenter"
            android:visibility="gone" />

        <com.android.systemui.weather.WeatherTextView
            android:id="@+id/weather_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:layout_marginStart="4dp"
            android:textColor="@android:color/white"
            android:visibility="gone"
            android:textSize="20sp" />
    </LinearLayout>

</LinearLayout>
