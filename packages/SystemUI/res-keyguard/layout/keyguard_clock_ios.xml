<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/clock_frame"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_gravity="center_horizontal|top"
    android:gravity="center_horizontal|top"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:orientation="vertical">
        
        <TextClock
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:format12Hour="EEE, MM dd"
            android:format24Hour="EEE, dd MM"
            android:gravity="center"
            android:singleLine="true"
            android:tag="text1|nolineheight"
            android:textAlignment="center"
            android:textColor="@android:color/white"
            android:textSize="20dp" 
            android:textStyle="bold" />
        <TextClock
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/tallclock"
            android:layout_marginTop="4dp"
            android:format12Hour="hhmm"
            android:format24Hour="HHmm"
            android:gravity="center"
            android:singleLine="true"
            android:tag="text1"
            android:textAlignment="center"
            android:textColor="@android:color/white"
            android:textSize="280dp" />

    </LinearLayout>

</LinearLayout>