<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/clock_frame"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_gravity="start|top"
    android:gravity="start|top"
    android:orientation="vertical">

    <TextClock
        android:textSize="100sp"
        android:textColor="@android:color/white"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:singleLine="true"
        android:fontFamily="@*android:string/config_clockFontFamily"
        android:format12Hour="hh:mm"
        android:format24Hour="HH:mm"/>

    <TextClock
        android:textSize="60sp"
        android:textColor="@android:color/white"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="-15.0dip"
        android:singleLine="true"
        android:textAlignment="viewStart"
        android:fontFamily="@*android:string/config_clockFontFamily"
        android:textAllCaps="true"
        android:format12Hour="EEE"
        android:format24Hour="EEE"/>

    <TextClock
        android:id="@+id/miui_date"
        android:textSize="60sp"
        android:textColor="@android:color/white"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="-10.0dip"
        android:singleLine="true"
        android:textAlignment="viewStart"
        android:fontFamily="@*android:string/config_clockFontFamily"
        android:format12Hour="MM/dd"
        android:format24Hour="MM/dd"/>

    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="start|center">

        <com.android.systemui.weather.WeatherImageView
            android:id="@+id/weather_image"
            android:layout_width="20sp"
            android:layout_height="20sp"
            android:layout_gravity="center_vertical"
            android:layout_marginEnd="4dp"
            android:scaleType="fitCenter"
            android:visibility="gone" />

        <com.android.systemui.weather.WeatherTextView
            android:id="@+id/miui_weather_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:layout_marginStart="4dp"
            android:fontFamily="@*android:string/config_clockFontFamily"
            android:textColor="@android:color/white"
            android:textSize="20sp"
            android:visibility="gone"
            android:textAllCaps="true" />
    </LinearLayout>
</LinearLayout>

